# ─── NEXUS environment ───────────────────────────────────────────────
# Copy to .env.local and fill in. Nothing here is required for Phase 0.

# Supabase (Phase 4+) — Postgres + pgvector + Auth + Storage
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only, never expose to the client

# LLM provider (Phase 6) — default: Gemini Flash (free)
LLM_PROVIDER=gemini                 # gemini | groq | claude
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=text-embedding-004

# Optional alternative providers (swappable via the adapter)
GROQ_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Ingestion (Phase 5) — GitHub source
GITHUB_TOKEN=                       # read-only PAT for repo + README fetch
GITHUB_USERNAME=

# Caching / rate limiting (Phase 6) — Upstash Redis (free)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Site URL (used in SEO metadata, JSON-LD, and share/QR links)
NEXT_PUBLIC_SITE_URL=

# Lead capture (networking) — Resend (free tier, 3k emails/mo)
# Without these, leads are still accepted and logged server-side, just not emailed.
RESEND_API_KEY=
RESEND_FROM_EMAIL=                  # e.g. "NEXUS <onboarding@resend.dev>"

# Product analytics + session replay — PostHog (free tier, 1M events/mo)
# Optional: layers on top of the built-in privacy-first analytics (lib/analytics.ts).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
